programa {
  funcao inicio() {

    inteiro variavel1 
    inteiro variavel2
    inteiro variavel3

    escreva("digite o valor da nota 1:")
    leia(variavel1)
    escreva("digite o valor da nota 2:")
    leia(variavel2)
    escreva("digite o valor da nota 3:")
    leia(variavel3)

    inteiro soma = variavel1 + variavel2  variavel3
    inteiro divisao = soma/3
    escreva("media", divisao)

}
  }
}
