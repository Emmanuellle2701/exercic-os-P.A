programa {
  funcao inicio() {
    
    real numero1, numero2, numero3, media

    escreva("Digite a primeira nota: ")
    leia(numero1)

    escreva("Digite a segunda nota: ")
    leia(numero2)

    escreva("Digite a terceira nota: ")
    leia(numero3)

    media = (numero1 + numero2 + numero3) / 3

    escreva("Média:", media)

  }
}
